generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// NextAuth Models
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  projects Project[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Application Models
// ──────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeys ApiKey[]

  @@index([slug])
  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  projectId  String
  name       String
  prefix     String // First 14 chars shown to user (e.g., "av_sk_ab1234")
  hash       String // SHA-256 hash of the full key
  scopes     String    @default("") @db.Text // JSON array of scope strings
  rateLimit  Int       @default(1000) // requests per hour
  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  usageLogs UsageLog[]

  @@index([projectId])
  @@index([hash])
  @@index([prefix])
}

model UsageLog {
  id        String   @id @default(cuid())
  apiKeyId  String
  endpoint  String
  method    String   @default("GET")
  status    Int      @default(200)
  latency   Int      @default(0) // milliseconds
  ip        String   @default("")
  createdAt DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([createdAt])
}
