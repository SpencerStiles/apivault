# APIVault — Environment Variables
# Copy this file to .env and fill in the values.
#
#   cp .env.example .env

# =============================================================================
# Database
# =============================================================================

# PostgreSQL connection string (use SQLite file:./dev.db for local dev)
DATABASE_URL="postgresql://user:password@localhost:5432/apivault"

# =============================================================================
# Authentication (NextAuth)
# =============================================================================

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# NextAuth base URL — set to your production domain in deployment
# Default: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# OAuth — GitHub
# =============================================================================

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers -> New OAuth App
# Set callback URL to: {NEXTAUTH_URL}/api/auth/callback/github
# Optional: app falls back to credentials auth if not set
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# =============================================================================
# Application
# =============================================================================

# Node environment (development | production | test)
# Default: development
NODE_ENV="development"

# Set to "true" to skip Zod env validation (useful in CI builds)
# SKIP_ENV_VALIDATION="true"
